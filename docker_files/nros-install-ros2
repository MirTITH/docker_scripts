#!/bin/bash
set -euo pipefail

ROS2_MIRROR_URL="http://mirrors.ustc.edu.cn/ros2/ubuntu"
ROS2_VERSION=""
INSTALL_GAZEBO=false
INSTALL_COLCON_MIXIN=false
ROSDEP_UPDATE=false

print_usage() {
  echo "Usage: $0 --ros2-version ROS2_VERSION [--mirror ROS2_MIRROR_URL] [--install-gazebo true|false] [--install-colcon-mixin true|false] [--rosdep-update true|false]"
  echo ""
  echo "Options:"
  echo "  --ros2-version ROS2_VERSION    Specify the ROS 2 version (e.g., humble, jazzy)"
  echo "  --mirror ROS2_MIRROR_URL        Specify the ROS 2 mirror URL (default: ${ROS2_MIRROR_URL})"
  echo "  --install-gazebo true|false     Whether to install Gazebo packages (default: ${INSTALL_GAZEBO})"
  echo "  --install-colcon-mixin true|false Whether to install colcon mixin (default: ${INSTALL_COLCON_MIXIN})"
  echo "  --rosdep-update true|false      Whether to run rosdep update after installation (default: ${ROSDEP_UPDATE})"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  --ros2-version)
    ROS2_VERSION="$2"
    shift 2
    ;;
  --mirror)
    ROS2_MIRROR_URL="$2"
    shift 2
    ;;
  --install-gazebo)
    INSTALL_GAZEBO="$2"
    shift 2
    ;;
  --install-colcon-mixin)
    INSTALL_COLCON_MIXIN="$2"
    shift 2
    ;;
  --rosdep-update)
    ROSDEP_UPDATE="$2"
    shift 2
    ;;
  --help | -h)
    print_usage
    exit 0
    ;;
  -*)
    echo "未知选项: $1"
    print_usage
    exit 1
    ;;
  *)
    echo "未知参数: $1"
    print_usage
    exit 1
    ;;
  esac
done

if [ -z "${ROS2_VERSION}" ]; then
  echo "错误: 必须指定 ROS 2 版本"
  print_usage
  exit 1
fi

sudo DEBIAN_FRONTEND=noninteractive apt-get update
sudo DEBIAN_FRONTEND=noninteractive apt-get install -y software-properties-common curl
sudo add-apt-repository universe
sudo DEBIAN_FRONTEND=noninteractive apt-get update
sudo curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key -o /usr/share/keyrings/ros-archive-keyring.gpg
echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] ${ROS2_MIRROR_URL} $(lsb_release -sc) main" | sudo tee /etc/apt/sources.list.d/ros2.list >/dev/null
sudo DEBIAN_FRONTEND=noninteractive apt-get update
sudo DEBIAN_FRONTEND=noninteractive apt-get upgrade -y
sudo DEBIAN_FRONTEND=noninteractive apt-get install -y ros-${ROS2_VERSION}-desktop ros-dev-tools

if [ "$INSTALL_GAZEBO" = true ]; then
  sudo DEBIAN_FRONTEND=noninteractive apt-get install -y ros-${ROS2_VERSION}-gazebo-ros-pkgs
fi

if [ "$INSTALL_COLCON_MIXIN" = true ]; then
  # colcon mixin
  sudo DEBIAN_FRONTEND=noninteractive apt-get install -y python3-colcon-common-extensions python3-colcon-mixin
  colcon mixin add default https://raw.githubusercontent.com/colcon/colcon-mixin-repository/master/index.yaml
  colcon mixin update default
fi

if [ "$ROSDEP_UPDATE" = true ]; then
  sudo rosdep init
  rosdep update
fi

sudo rm -rf /var/lib/apt/lists/*
